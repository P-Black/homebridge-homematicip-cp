{
  "name": "homebridge-homematicip-cp",
  "version": "1.3.22",
  "description": "P-Black CP build of the Homematic IP Homebridge plugin, based on the original homebridge-homematicip project by marcsowen. Includes Homebridge 2.x compatibility and CP-specific Apple Home improvements.",
  "license": "Apache-2.0",
  "author": "P-Black",
  "keywords": [
    "homebridge-plugin",
    "homekit",
    "homematic",
    "homematicip",
    "hmip"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/P-Black/homebridge-homematicip-cp.git"
  },
  "bugs": {
    "url": "https://github.com/P-Black/homebridge-homematicip-cp/issues"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "rimraf ./dist && tsc",
    "watch": "npm run build && nodemon",
    "prepack": "npm run build",
    "lint": "eslint src/**/*.ts"
  },
  "engines": {
    "node": ">=20.0.0",
    "homebridge": ">=1.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/ws": "^8.5.3",
    "@typescript-eslint/eslint-plugin": "^5.40.0",
    "@typescript-eslint/parser": "^5.40.0",
    "abort-controller": "^3.0.0",
    "eslint": "^8.25.0",
    "homebridge": "^2.0.0",
    "nodemon": "^2.0.20",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "bottleneck": "^2.19.5",
    "fakegato-history": "^0.6.3",
    "moment": "^2.29.4",
    "semver": "^7.3.8",
    "ws": "^8.9.0"
  },
  "files": [
    "dist",
    "config.schema.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "NOTICE"
  ],
  "displayName": "Homebridge Homematicip",
  "homepage": "https://github.com/P-Black/homebridge-homematicip-cp#readme",
  "contributors": [
    "marcsowen (original homebridge-homematicip project)"
  ]
